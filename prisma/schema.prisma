// Covenant Prisma Schema (SQLite for hackathon/demo)
generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                  String   @id @default(cuid())
  title               String
  description         String
  fundingGoal         String   // micro units as string
  milestoneDescription String
  deadlineBlock       Int      // Stacks block height (derived from deadlineAt)
  deadlineAt          DateTime? // the builder's chosen deadline date + time
  disputeWindowBlocks Int      @default(144) // ~48h on testnet approx
  builderAddress      String
  treasuryAddress     String   // builder's receive addr, usually same or separate
  judges              String   @default("[]") // JSON array of appointed judge principals (chosen by investors)
  minFundingBps       Int      @default(10000) // minimum to proceed, basis points of goal (10000 = 100%)
  builderAcceptedPartial Boolean @default(false) // builder chose to proceed under the minimum
  status              String   @default("CREATED") // CREATED | BACKING_OPEN | POOLED_LOCKED | DISPUTE_WINDOW | RESOLVED_SUCCESS | RESOLVED_FAILURE
  pooledTxid          String?  // tx when custodian pooled
  pooledExplorerUrl   String?
  withdrawTxid        String?
  withdrawExplorerUrl String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  contributions       BackerContribution[]
  attestations        JudgeAttestation[]
  stateLogs           ProjectStateLog[]
  distributions       Distribution[]
}

model BackerContribution {
  id              String   @id @default(cuid())
  projectId       String
  principal       String   // investor STX addr
  amount          String   // micro
  status          String   @default("ACTIVE") // ACTIVE | WITHDRAWN
  depositTxid     String?  // user to custodian transfer tx (off-vault)
  depositExplorerUrl String?
  refundTxid      String?  // custodian refund tx if withdrawn
  refundExplorerUrl String?
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id])
}

model JudgeAttestation {
  id          String   @id @default(cuid())
  projectId   String
  judge       String   // configured judge principal
  vote        String   // "MET" | "NOT_MET"
  signature   String   // signed message for verification
  signedAt    DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, judge])
}

model ProjectStateLog {
  id          String   @id @default(cuid())
  projectId   String
  status      String
  note        String?
  txid        String?
  explorerUrl String?
  timestamp   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
}

model Distribution {
  id              String   @id @default(cuid())
  projectId       String
  recipient       String
  amount          String
  txid            String
  explorerUrl     String
  kind            String   // "BUILDER_PAYOUT" | "BACKER_REWARD" | "REFUND"
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id])
}

// Reputation scores across any successful vault resolution
model Reputation {
  id          String   @id @default(cuid())
  principal   String   @unique
  score       Int      @default(0)  // +1 per successful resolution involving them
  updatedAt   DateTime @updatedAt
}

// For Payroll Feature A
model PayrollVault {
  id                String   @id @default(cuid())
  payerAddress      String
  contributorAddress String
  totalBudget       String
  intervalAmount    String
  releasedAmount    String   @default("0") // running total streamed to the contributor
  depositTxid       String?  // payer's wallet deposit of the budget to the custodian
  depositExplorerUrl String?
  startBlock        Int      @default(0)
  endBlock          Int      @default(0)
  lastReleasedBlock Int?
  status            String   @default("ACTIVE") // ACTIVE | CLAWBACK | COMPLETED
  clawbackTxid      String?
  clawbackExplorerUrl String?
  createdAt         DateTime @default(now())

  checkIns          CheckIn[]
}

model CheckIn {
  id              String   @id @default(cuid())
  payrollId       String
  principal       String
  intervalBlock   Int
  amount          String?  // amount released on this check-in
  txid            String?  // on-chain release tx
  explorerUrl     String?
  createdAt       DateTime @default(now())

  payroll         PayrollVault @relation(fields: [payrollId], references: [id])
}

// For Reputation Vault Feature B
model ReputationVault {
  id                String @id @default(cuid())
  title             String
  totalAmount       String
  lockUntilBlock    Int      @default(0)
  status            String @default("OPEN") // OPEN | DISTRIBUTED
  depositTxid       String?  // creator's wallet deposit of the pool to the custodian
  depositExplorerUrl String?
  pooledTxid        String?
  resolvedTxid      String?
  resolvedExplorerUrl String?
  payouts           String   @default("[]") // JSON [{recipient, amount, txid, explorerUrl}]
  createdAt         DateTime @default(now())
  participants      ReputationVaultParticipant[]
}

model ReputationVaultParticipant {
  id                String @id @default(cuid())
  vaultId           String
  principal         String
  reputationAtTime  Int
  computedShareBps  Int   // basis points of total
  vault             ReputationVault @relation(fields: [vaultId], references: [id])
}

// For Insurance Pool Feature C
model InsurancePool {
  id               String  @id @default(cuid())
  title            String
  triggerCondition String  @default("INCIDENT_DECLARED")
  lockUntilBlock   Int      @default(0)
  returnOnExpiry   String  @default("REFUND") // REFUND | ROLL
  status           String  @default("OPEN") // OPEN | PAID_OUT | REFUNDED | ROLLED
  pooledTxid       String?
  resolvedTxid     String?
  resolvedExplorerUrl String?
  payouts          String   @default("[]") // JSON [{recipient, amount, txid, explorerUrl}]
  createdAt        DateTime @default(now())

  contributions    InsuranceContribution[]
}

model InsuranceContribution {
  id            String   @id @default(cuid())
  poolId        String
  principal     String
  amount        String
  depositTxid   String?  // member's wallet premium deposit to the custodian
  depositExplorerUrl String?
  createdAt     DateTime @default(now())
  pool          InsurancePool @relation(fields: [poolId], references: [id])
}

model InsuranceClaim {
  id        String @id @default(cuid())
  poolId    String
  principal String
  amount    String?
}
