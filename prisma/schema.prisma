// Covenant Prisma Schema (SQLite / libSQL-Turso)
//
// Grant-distribution model: a Grantor funds a program into a dedicated on-chain
// escrow custodian, a Builder applies, and on acceptance the Grantor defines a
// sequential milestone schedule. Each milestone's tranche is time-locked in
// FlowVault until its deadline and auto-disbursed (if judges attested MET) or
// auto-returned to the grantor (if not) by the reconcile engine.
generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

// A grant program created and funded by a single grantor.
model GrantProgram {
  id                   String   @id @default(cuid())
  title                String
  description          String
  conditions           String   @default("") // eligibility criteria for applicants
  grantorAddress       String
  totalPool            String   // micro units as string
  custodianAddress     String   @default("") // per-program derived escrow custodian
  programDeadlineAt    DateTime? // horizon by which all milestones must resolve
  programDeadlineBlock Int      @default(0)
  status               String   @default("DRAFT") // DRAFT | FUNDED_OPEN | AWARDED | COMPLETED | EXPIRED
  fundTxid             String?  // grantor's wallet -> custodian funding transfer
  fundExplorerUrl      String?
  lockTxid             String?  // custodian's first FlowVault lock (at award)
  lockExplorerUrl      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  applications         Application[]
  award                Award?
  stateLogs            ProgramStateLog[]
}

// A builder's application (pitch) to an open grant program.
model Application {
  id             String   @id @default(cuid())
  programId      String
  builderAddress String
  pitch          String
  contact        String?
  status         String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  createdAt      DateTime @default(now())

  program        GrantProgram @relation(fields: [programId], references: [id])
}

// The single accepted award for a program (one-builder-per-program).
model Award {
  id                  String   @id @default(cuid())
  programId           String   @unique
  applicationId       String
  builderAddress      String
  amount              String   // micro; equals the program pool for single-award
  judges              String   @default("[]") // JSON array of judge principals (set by grantor)
  status              String   @default("ACTIVE") // ACTIVE | COMPLETED | FAILED
  activeMilestoneIndex Int     @default(0) // sequential pointer
  createdAt           DateTime @default(now())

  program             GrantProgram   @relation(fields: [programId], references: [id])
  milestones          Milestone[]
  distributions       Distribution[]
}

// One tranche of an award, gated on a deadline + judge attestation.
model Milestone {
  id                String   @id @default(cuid())
  awardId           String
  index             Int      // 0-based, sequential
  name              String
  description       String   @default("")
  deadlineAt        DateTime?
  deadlineBlock     Int      @default(0)
  percentBps        Int      // basis points of the award (sums to 10000)
  amount            String   // micro; last milestone absorbs rounding
  lockUntilBlock    Int      @default(0) // FlowVault lock target for this tranche
  status            String   @default("LOCKED") // LOCKED | READY_FOR_REVIEW | ATTESTED_MET | PAID | EXPIRED
  withdrawTxid      String?  // custodian frees the remaining balance from FlowVault
  withdrawExplorerUrl String?
  payoutTxid        String?  // custodian -> builder tranche transfer
  payoutExplorerUrl String?
  relockTxid        String?  // re-lock of the remainder after this tranche pays
  relockExplorerUrl String?
  createdAt         DateTime @default(now())

  award             Award    @relation(fields: [awardId], references: [id])
  attestations      MilestoneAttestation[]

  @@unique([awardId, index])
}

// A judge's wallet-signed vote on one milestone (server-verified).
model MilestoneAttestation {
  id          String   @id @default(cuid())
  milestoneId String
  judge       String
  vote        String   // "MET" | "NOT_MET"
  signature   String
  signedAt    DateTime @default(now())

  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  @@unique([milestoneId, judge])
}

// On-chain payout / return ledger for an award.
model Distribution {
  id          String   @id @default(cuid())
  awardId     String
  recipient   String
  amount      String
  txid        String
  explorerUrl String
  kind        String   // "MILESTONE_PAYOUT" | "GRANTOR_RETURN"
  createdAt   DateTime @default(now())

  award       Award    @relation(fields: [awardId], references: [id])
}

// Program audit trail.
model ProgramStateLog {
  id          String   @id @default(cuid())
  programId   String
  status      String
  note        String?
  txid        String?
  explorerUrl String?
  timestamp   DateTime @default(now())

  program     GrantProgram @relation(fields: [programId], references: [id])
}

// Reputation scores across any successful resolution.
model Reputation {
  id          String   @id @default(cuid())
  principal   String   @unique
  score       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

// ------------------------------------------------------------------
// Secondary vault features (unchanged): Payroll, Reputation, Insurance
// ------------------------------------------------------------------

model PayrollVault {
  id                String   @id @default(cuid())
  payerAddress      String
  contributorAddress String
  totalBudget       String
  intervalAmount    String
  releasedAmount    String   @default("0")
  depositTxid       String?
  depositExplorerUrl String?
  startBlock        Int      @default(0)
  endBlock          Int      @default(0)
  lastReleasedBlock Int?
  status            String   @default("ACTIVE") // ACTIVE | CLAWBACK | COMPLETED
  clawbackTxid      String?
  clawbackExplorerUrl String?
  createdAt         DateTime @default(now())

  checkIns          CheckIn[]
}

model CheckIn {
  id              String   @id @default(cuid())
  payrollId       String
  principal       String
  intervalBlock   Int
  amount          String?
  txid            String?
  explorerUrl     String?
  createdAt       DateTime @default(now())

  payroll         PayrollVault @relation(fields: [payrollId], references: [id])
}

model ReputationVault {
  id                String @id @default(cuid())
  title             String
  totalAmount       String
  lockUntilBlock    Int      @default(0)
  status            String @default("OPEN") // OPEN | DISTRIBUTED
  depositTxid       String?
  depositExplorerUrl String?
  pooledTxid        String?
  resolvedTxid      String?
  resolvedExplorerUrl String?
  payouts           String   @default("[]")
  createdAt         DateTime @default(now())
  participants      ReputationVaultParticipant[]
}

model ReputationVaultParticipant {
  id                String @id @default(cuid())
  vaultId           String
  principal         String
  reputationAtTime  Int
  computedShareBps  Int
  vault             ReputationVault @relation(fields: [vaultId], references: [id])
}

model InsurancePool {
  id               String  @id @default(cuid())
  title            String
  triggerCondition String  @default("INCIDENT_DECLARED")
  lockUntilBlock   Int      @default(0)
  returnOnExpiry   String  @default("REFUND") // REFUND | ROLL
  status           String  @default("OPEN") // OPEN | PAID_OUT | REFUNDED | ROLLED
  pooledTxid       String?
  resolvedTxid     String?
  resolvedExplorerUrl String?
  payouts          String   @default("[]")
  createdAt        DateTime @default(now())

  contributions    InsuranceContribution[]
}

model InsuranceContribution {
  id            String   @id @default(cuid())
  poolId        String
  principal     String
  amount        String
  depositTxid   String?
  depositExplorerUrl String?
  createdAt     DateTime @default(now())
  pool          InsurancePool @relation(fields: [poolId], references: [id])
}

model InsuranceClaim {
  id        String @id @default(cuid())
  poolId    String
  principal String
  amount    String?
}
